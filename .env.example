APP_NAME=Bre-AI
APP_ENV=development

POSTGRES_DB=bre_ai
POSTGRES_USER=bre_user
POSTGRES_PASSWORD=change-this-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://bre_user:change-this-password@db:5432/bre_ai

JWT_SECRET=change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

DEFAULT_ADMIN_EMAIL=admin@bre.ai
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
DEFAULT_ADMIN_DISPLAY_NAME=Admin Bre-AI

BACKEND_PORT=8000
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

UPLOAD_DIR=/app/storage/uploads
OUTPUT_DIR=/app/storage/outputs
